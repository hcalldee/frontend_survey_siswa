<%
  const pageBody = `
<style>
  :root{
    --col-no: 46px;
    --col-q: 320px;
  }

  /* Layout dasar */
  #form-content { padding: 0.75rem; }

  #tabel-rating td, #tabel-rating th { vertical-align: middle; }
  #tabel-rating .br-widget a { font-size: 22px; padding: 2px 2px; }

  /* Fix icon bintang: theme fontawesome-stars defaultnya FA4 */
  .br-theme-fontawesome-stars .br-widget a:after {
    font-family: "Font Awesome 5 Free" !important;
    font-weight: 900 !important;
  }

  /* Kolom rating (mulai kolom ke-3) dikasih lebar supaya swipe kerasa */
  #tabel-rating tr > :nth-child(n+3){
    min-width: 140px;
    text-align: center;
  }

  /* Wrapper tabel: scroll horizontal + vertical khusus tabel */
  .rating-table-shell{
    width: 100%;
    max-width: 100%;
    display: block;

    max-height: 60vh;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x pan-y;
    overscroll-behavior: contain;

    border: 1px solid rgba(0,0,0,.1);
    border-radius: .25rem;
    background: #fff;
  }

  /* Biar tabel bisa melebar mengikuti jumlah instruktur */
  #tabel-rating{
    width: max-content;
    min-width: 100%;
    margin-bottom: 0;
  }

  /* Default kolom jangan wrap */
  #tabel-rating th, #tabel-rating td { white-space: nowrap; }

  /* Pertanyaan boleh wrap dan fix width */
  #tabel-rating td:nth-child(2),
  #tabel-rating th:nth-child(2),
  #tabel-rating td.w-40 {
    white-space: normal !important;
    min-width: var(--col-q);
    max-width: var(--col-q);
    word-break: break-word;
  }

  /* Sticky kolom No */
  #tabel-rating tr > :first-child{
    position: sticky;
    left: 0;
    min-width: var(--col-no);
    width: var(--col-no);
    background: #fff;
    z-index: 5;
  }

  /* Sticky kolom Pertanyaan */
  #tabel-rating tr > :nth-child(2){
    position: sticky;
    left: var(--col-no);
    background: #fff;
    z-index: 4;
  }

  /* Header backgrounds supaya sticky rapi */
  #tabel-rating tr.table-primary > th,
  #tabel-rating tr.table-primary > td{ background: #cfe2ff !important; }

  #tabel-rating tr.table-secondary > th,
  #tabel-rating tr.table-secondary > td{ background: #e2e3e5 !important; }

  #tabel-rating tr.table-info > th,
  #tabel-rating tr.table-info > td{ background: #cff4fc !important; }

  #tabel-rating textarea{ min-height: 70px; font-size: 14px; }

  @media (max-width: 480px){
    :root{ --col-q: 250px; }
    #tabel-rating .br-widget a { font-size: 20px; }
  }

  @media (max-width: 768px){
    .rating-table-shell{ max-height: 70vh; }
  }
</style>

<h1 class="h3 mb-3 text-gray-800">Form Quisioner</h1>

<!-- NOTE: no card wrapper, biar nggak nested -->
<div>
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h6 class="m-0 font-weight-bold text-primary" id="content-title"></h6>
  </div>

  <div id="form-content">
    <div id="bag-konfirmasi">
      <table>
        <thead>
          <tr>
            <td class="text-start">
              <img src="https://kemnaker.go.id/assets/images/logo-color.png" alt="" class="img-fluid w-50" />
            </td>
          </tr>
        </thead>
      </table>
      <br><br>
      <h3 class="text-center"><b>EVALUASI PENYELENGGARAAN PELATIHAN</b></h3>
      <p class="text-start">
        Dalam rangka meningkatkan mutu penyelenggaraan pelatihan dimasa mendatang, serta pengukuran kepuasan pelanggan maka kami mohon kesediaan Anda untuk mengisi kuisioner ini dengan memberikan penilaian yang sejujurnya. Penilaian anda dijamin kerahasiaannya. Terimakasih
      </p>
      <br><br>
      <p class="text-start">Keterangan :</p>
      <ul>5 : Baik Sekali</ul>
      <ul>4 : Baik</ul>
      <ul>3 : Cukup/Sedang</ul>
      <ul>2 : Kurang Baik</ul>
      <ul>1 : Tidak Baik</ul>
    </div>

    <div class="table-responsive" id="bag-data" hidden>
      <table class="table table-bordered border-primary">
        <tbody>
          <tr>
            <td style="width: 20%;">
              <div class="form-group">
                <label>Sumber Informasi</label>
                <select id="informasi" class="form-control jawaban-rating"></select>
              </div>
            </td>
            <td style="width: 30%;">
              <div class="form-group">
                <label>Nama Pelatihan</label>
                <select id="pelatihan" class="form-control jawaban-rating"></select>
              </div>
            </td>
            <td style="width: 20%;">
              <div class="form-group">
                <label>Tanggal Pelatihan</label>
                <textarea class="form-control" id="tanggal" disabled></textarea>
              </div>
            </td>
            <td style="width: 15%;">
              <label>Instruktur</label>
              <div class="form-content" id="data-instruktur"></div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div id="bag-quisioner" hidden>
      <div class="small text-muted mb-2">Geser ke kanan/kiri untuk lihat kolom penilaian. Scroll ke bawah untuk lanjut pertanyaan.</div>
      <div class="rating-table-shell">
        <table class="table table-bordered border-primary" id="tabel-rating">
          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-3" id="form-footer">
    <div class="d-flex justify-content-end">
      <button class="btn btn-primary" id="btn-navigation-a">Mengerti, Lanjutkan</button>
    </div>
  </div>
</div>
  `;

  const pageScripts = `<script src="/public/js/form-quisioner.js"></script>`;
%>

<%- include("../layouts/main", { title: "Form Quisioner", apiBase, body: pageBody, scripts: pageScripts }) %>

